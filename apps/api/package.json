{
  "name": "@elite/api",
  "version": "0.0.1",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "echo 'no lint'",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:cleanup": "tsx scripts/cleanupSeedData.ts",
    "db:reset:dev": "tsx scripts/resetDevDb.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@elite/shared": "workspace:*",
    "@prisma/client": "^5.18.0",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "next": "14.2.35",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/supertest": "^2.0.16",
    "prisma": "^5.18.0",
    "supertest": "^6.3.4",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
