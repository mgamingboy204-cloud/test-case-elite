{
  "compilerOptions": {
    "outDir": "dist",
    "module": "Node16",
    "target": "ES2020",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": [
    "src"
  ],
  "exclude": [
    "prisma",
    "tests"
  ]
}
