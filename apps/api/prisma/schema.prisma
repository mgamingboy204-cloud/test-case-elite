generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
 
}

enum Role {
  USER
  EMPLOYEE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
}

enum GenderPreference {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  ALL
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
}

enum OnboardingStep {
  PHONE_VERIFIED
  VIDEO_VERIFICATION_PENDING
  VIDEO_VERIFIED
  PAYMENT_PENDING
  PAID
  PROFILE_PENDING
  ACTIVE
}

enum VideoVerificationStatus {
  NOT_REQUESTED
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum OnboardingPaymentStatus {
  NOT_STARTED
  PENDING
  PAID
  FAILED
  CANCELED
}

enum PaymentPlan {
  ONE_MONTH
  FIVE_MONTHS
  TWELVE_MONTHS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
  MOCK
}

enum LikeType {
  LIKE
  PASS
}

enum ConsentResponse {
  YES
  NO
}

enum ConsentType {
  PHONE_NUMBER
  OFFLINE_MEET
  ONLINE_MEET
  SOCIAL_EXCHANGE
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum RefundStatus {
  PENDING
  APPROVED
  DENIED
}

enum VerificationRequestStatus {
  REQUESTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REJECTED
  TIMED_OUT
}

enum NotificationType {
  NEW_LIKE
  NEW_MATCH
  NEW_MESSAGE
  SYSTEM_PROMO
  PROFILE_VIEW
  VIDEO_VERIFICATION_UPDATE
  OFFLINE_MEET_REQUEST
  OFFLINE_MEET_ACCEPTED
  OFFLINE_MEET_OPTIONS_SENT
  OFFLINE_MEET_TIMEOUT
  OFFLINE_MEET_NO_OVERLAP
  OFFLINE_MEET_FINALIZED
  OFFLINE_MEET_RESCHEDULE_UPDATE
  ONLINE_MEET_REQUEST
  ONLINE_MEET_ACCEPTED
  ONLINE_MEET_OPTIONS_SENT
  ONLINE_MEET_TIMEOUT
  ONLINE_MEET_NO_OVERLAP
  ONLINE_MEET_FINALIZED
  ONLINE_MEET_RESCHEDULE_UPDATE
  SOCIAL_EXCHANGE_REQUEST
  SOCIAL_EXCHANGE_ACCEPTED
  SOCIAL_EXCHANGE_REJECTED
  SOCIAL_EXCHANGE_HANDLE_READY
  SOCIAL_EXCHANGE_VIEWED
  SOCIAL_EXCHANGE_EXPIRED
  SOCIAL_EXCHANGE_RESEND_AVAILABLE
  PHONE_EXCHANGE_REQUEST
  PHONE_EXCHANGE_ACCEPTED
  PHONE_EXCHANGE_REJECTED
  PHONE_EXCHANGE_MUTUAL_CONSENT_CONFIRMED
  PHONE_EXCHANGE_REVEALED
}

enum PhoneExchangeCaseStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  MUTUAL_CONSENT_CONFIRMED
  REVEALED
  CANCELED
}

enum SocialExchangeStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  AWAITING_HANDLE_SUBMISSION
  HANDLE_SUBMITTED
  READY_TO_REVEAL
  REVEALED
  EXPIRED
  COOLDOWN
  CANCELED
}

enum SocialPlatform {
  SNAPCHAT
  INSTAGRAM
  LINKEDIN
}

enum OfflineMeetCoordinationStatus {
  REQUESTED
  ACCEPTED
  EMPLOYEE_PREPARING_OPTIONS
  OPTIONS_SENT
  AWAITING_USER_SELECTIONS
  USER_ONE_RESPONDED
  USER_TWO_RESPONDED
  READY_FOR_FINALIZATION
  FINALIZED
  NO_RESPONSE_TIMEOUT
  NO_COMPATIBLE_OVERLAP
  COOLDOWN
  CANCELED
  RESCHEDULE_REQUESTED
}


enum OnlineMeetCoordinationStatus {
  REQUESTED
  ACCEPTED
  EMPLOYEE_PREPARING_OPTIONS
  OPTIONS_SENT
  AWAITING_USER_SELECTIONS
  USER_ONE_RESPONDED
  USER_TWO_RESPONDED
  READY_FOR_FINALIZATION
  FINALIZED
  NO_RESPONSE_TIMEOUT
  NO_COMPATIBLE_OVERLAP
  COOLDOWN
  CANCELED
  RESCHEDULE_REQUESTED
}

enum SubscriptionTier {
  FREE
  PREMIUM
  ELITE
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  displayName  String?
  gender       Gender?
  role         Role     @default(USER)
  employeeId   String?  @unique
  isAdmin      Boolean  @default(false)
  status       UserStatus @default(PENDING)
  onboardingStep OnboardingStep @default(PHONE_VERIFIED)
  videoVerificationStatus VideoVerificationStatus @default(NOT_REQUESTED)
  paymentStatus OnboardingPaymentStatus @default(NOT_STARTED)
  subscriptionTier SubscriptionTier @default(FREE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt DateTime?
  manualRenewalRequired Boolean @default(true)
  isVideoVerified Boolean @default(false)
  videoUrl String?
  onboardingToken String? @unique
  onboardingTokenExpiresAt DateTime?
  onboardingPaymentRef String?
  onboardingPaymentPlan PaymentPlan?
  onboardingPaymentAmount Int?
  onboardingPaymentVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  verifiedAt   DateTime?
  phoneVerifiedAt DateTime?
  profileCompletedAt DateTime?
  deactivatedAt DateTime?
  deletedAt DateTime?
  assignedEmployeeId String?
  assignedAt DateTime?
  verifiedByEmployeeId String?

  profile       Profile?
  preferences   UserPreference?
  photos        Photo[]
  payments      Payment[]
  deviceTokens  DeviceToken[]
  likesSent     Like[]   @relation("likesSent")
  likesReceived Like[]   @relation("likesReceived")
  matchesA      Match[]  @relation("matchesA")
  matchesB      Match[]  @relation("matchesB")
  consents      Consent[]
  reportsSent   Report[] @relation("reportsSent")
  reportsRecv   Report[] @relation("reportsRecv")
  refunds       RefundRequest[]
  verificationSlots VerificationSlot[]
  verificationRequests VerificationRequest[]
  notifications Notification[] @relation("userNotifications")
  notificationsSent Notification[] @relation("notificationActors")
  auditLogs     AuditLog[] @relation("actorLogs")
  offlineMeetRequestsSent OfflineMeetCase[] @relation("offlineMeetRequester")
  offlineMeetRequestsReceived OfflineMeetCase[] @relation("offlineMeetReceiver")
  offlineMeetAssignments OfflineMeetCase[] @relation("offlineMeetAssignee")
  onlineMeetRequestsSent OnlineMeetCase[] @relation("onlineMeetRequester")
  onlineMeetRequestsReceived OnlineMeetCase[] @relation("onlineMeetReceiver")
  onlineMeetAssignments OnlineMeetCase[] @relation("onlineMeetAssignee")
  socialExchangeRequestsSent SocialExchangeCase[] @relation("socialExchangeRequester")
  socialExchangeRequestsReceived SocialExchangeCase[] @relation("socialExchangeReceiver")
  phoneExchangeRequestsSent PhoneExchangeCase[] @relation("phoneExchangeRequester")
  phoneExchangeRequestsReceived PhoneExchangeCase[] @relation("phoneExchangeReceiver")
  assignedEmployee User? @relation("MemberExecutive", fields: [assignedEmployeeId], references: [id])
  managedMembers User[] @relation("MemberExecutive")
  verifiedByEmployee User? @relation("VerifiedByEmployee", fields: [verifiedByEmployeeId], references: [id])
  verifiedMembers User[] @relation("VerifiedByEmployee")
}

model Profile {
  userId      String @id
  name        String
  gender      Gender
  age         Int
  dateOfBirth DateTime?
  city        String
  profession  String
  bioShort    String
  story       String?
  locationLabel String?
  heightCm    Int?
  intent      String  @default("dating")

  user User @relation(fields: [userId], references: [id])
}

model Photo {
  id        String   @id @default(uuid())
  userId    String
  url       String
  cropX     Float?
  cropY     Float?
  cropZoom  Float?
  photoIndex Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserPreference {
  userId String @id
  pushNotificationsEnabled Boolean @default(true)
  profileVisible Boolean @default(true)
  showOnlineStatus Boolean @default(true)
  discoverableByPremiumOnly Boolean @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PendingUser {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("PendingUser")
}

model OtpCode {
  phone     String @id
  codeHash  String
  expiresAt DateTime
  attempts  Int
  createdAt DateTime @default(now())
}

model Payment {
  id      String @id @default(uuid())
  userId  String
  plan    PaymentPlan
  amount  Int
  status  PaymentStatus
  paidAt  DateTime?

  user User @relation(fields: [userId], references: [id])
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Like {
  id         String   @id @default(uuid())
  actionId   String   @unique
  actorUserId String @map("fromUserId")
  targetUserId   String @map("toUserId")
  action       LikeType @map("type")
  createdAt  DateTime @default(now())

  actorUser User @relation("likesSent", fields: [actorUserId], references: [id])
  targetUser   User @relation("likesReceived", fields: [targetUserId], references: [id])

  @@unique([actorUserId, targetUserId])
  @@index([targetUserId, action, createdAt(sort: Desc)])
  @@index([actorUserId, action, createdAt(sort: Desc)])
  @@index([actorUserId, targetUserId])
}

model Match {
  id       String   @id @default(uuid())
  userAId  String
  userBId  String
  createdAt DateTime @default(now())
  unmatchedAt DateTime?
  unmatchedByUserId String?

  userA User @relation("matchesA", fields: [userAId], references: [id])
  userB User @relation("matchesB", fields: [userBId], references: [id])
  consents Consent[]
  phoneExchange PhoneExchangeEvent?
  phoneExchangeCase PhoneExchangeCase?
  offlineMeet OfflineMeetEvent?
  offlineMeetCase OfflineMeetCase?
  onlineMeet OnlineMeetEvent?
  onlineMeetCase OnlineMeetCase?
  socialExchange SocialExchangeEvent?
  socialExchangeCases SocialExchangeCase[]
  notifications Notification[]

  @@unique([userAId, userBId])
  @@index([userAId, unmatchedAt])
  @@index([userBId, unmatchedAt])
}

model PhoneExchangeCase {
  id        String @id @default(uuid())
  matchId   String @unique
  requesterUserId String
  receiverUserId String
  status    PhoneExchangeCaseStatus @default(REQUESTED)
  requesterConsented Boolean @default(true)
  receiverConsented Boolean @default(false)
  requestedAt DateTime @default(now())
  acceptedAt DateTime?
  rejectedAt DateTime?
  mutuallyConfirmedAt DateTime?
  revealedAt DateTime?
  revealedByUserId String?
  canceledAt DateTime?
  canceledByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id])
  requester User @relation("phoneExchangeRequester", fields: [requesterUserId], references: [id])
  receiver User @relation("phoneExchangeReceiver", fields: [receiverUserId], references: [id])

  @@index([requesterUserId, status])
  @@index([receiverUserId, status])
}

model OfflineMeetCase {
  id        String @id @default(uuid())
  matchId   String @unique
  requesterUserId String
  receiverUserId String
  assignedEmployeeId String?
  status OfflineMeetCoordinationStatus @default(REQUESTED)
  cafeOptions Json?
  timeSlotOptions Json?
  requesterCafeSelections Json?
  receiverCafeSelections Json?
  requesterTimeSelections Json?
  receiverTimeSelections Json?
  optionsSentAt DateTime?
  responseDeadlineAt DateTime?
  cooldownUntil DateTime?
  timeoutUserId String?
  finalCafe Json?
  finalTimeSlot Json?
  canceledAt DateTime?
  canceledByUserId String?
  cancelReason String?
  rescheduleRequestedByUserId String?
  rescheduleReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id])
  requester User @relation("offlineMeetRequester", fields: [requesterUserId], references: [id])
  receiver User @relation("offlineMeetReceiver", fields: [receiverUserId], references: [id])
  assignedEmployee User? @relation("offlineMeetAssignee", fields: [assignedEmployeeId], references: [id])

  @@index([assignedEmployeeId, status])
  @@index([requesterUserId])
  @@index([receiverUserId])
  @@index([status, responseDeadlineAt])
}



model OnlineMeetCase {
  id        String @id @default(uuid())
  matchId   String @unique
  requesterUserId String
  receiverUserId String
  assignedEmployeeId String?
  status OnlineMeetCoordinationStatus @default(REQUESTED)
  platformOptions Json?
  timeSlotOptions Json?
  requesterPlatformPreference String?
  receiverPlatformPreference String?
  requesterTimeSelections Json?
  receiverTimeSelections Json?
  optionsSentAt DateTime?
  responseDeadlineAt DateTime?
  cooldownUntil DateTime?
  timeoutUserId String?
  finalPlatform String?
  finalTimeSlot Json?
  finalMeetingLink String?
  canceledAt DateTime?
  canceledByUserId String?
  cancelReason String?
  rescheduleRequestedByUserId String?
  rescheduleReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id])
  requester User @relation("onlineMeetRequester", fields: [requesterUserId], references: [id])
  receiver User @relation("onlineMeetReceiver", fields: [receiverUserId], references: [id])
  assignedEmployee User? @relation("onlineMeetAssignee", fields: [assignedEmployeeId], references: [id])

  @@index([assignedEmployeeId, status])
  @@index([requesterUserId])
  @@index([receiverUserId])
  @@index([status, responseDeadlineAt])
}

model Consent {
  id         String @id @default(uuid())
  matchId    String
  userId     String
  type       ConsentType @default(PHONE_NUMBER)
  response   ConsentResponse
  payload    Json?
  respondedAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
  user  User @relation(fields: [userId], references: [id])

  @@unique([matchId, userId, type])
  @@index([matchId, type])
}

model PhoneExchangeEvent {
  id        String @id @default(uuid())
  matchId   String @unique
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

model OfflineMeetEvent {
  id        String @id @default(uuid())
  matchId   String @unique
  createdAt DateTime @default(now())
  details   Json?

  match Match @relation(fields: [matchId], references: [id])
}

model OnlineMeetEvent {
  id        String @id @default(uuid())
  matchId   String @unique
  createdAt DateTime @default(now())
  details   Json?

  match Match @relation(fields: [matchId], references: [id])
}

model SocialExchangeEvent {
  id        String @id @default(uuid())
  matchId   String @unique
  createdAt DateTime @default(now())
  details   Json?

  match Match @relation(fields: [matchId], references: [id])
}

model SocialExchangeCase {
  id        String @id @default(uuid())
  matchId   String
  requesterUserId String
  receiverUserId String
  status    SocialExchangeStatus @default(REQUESTED)
  platform  SocialPlatform?
  handleValue String?
  requestedAt DateTime @default(now())
  acceptedAt DateTime?
  rejectedAt DateTime?
  submittedAt DateTime?
  revealOpenedAt DateTime?
  revealExpiresAt DateTime?
  unopenedExpiresAt DateTime?
  expiredAt DateTime?
  cooldownUntil DateTime?
  canceledAt DateTime?
  canceledByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id])
  requester User @relation("socialExchangeRequester", fields: [requesterUserId], references: [id])
  receiver User @relation("socialExchangeReceiver", fields: [receiverUserId], references: [id])

  @@index([matchId, createdAt(sort: Desc)])
  @@index([requesterUserId, status])
  @@index([receiverUserId, status])
}

model Report {
  id             String @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  details        String?
  status         ReportStatus @default(OPEN)
  createdAt      DateTime @default(now())

  reporter     User @relation("reportsSent", fields: [reporterId], references: [id])
  reportedUser User @relation("reportsRecv", fields: [reportedUserId], references: [id])
}

model RefundRequest {
  id        String @id @default(uuid())
  userId    String
  requestedAt DateTime @default(now())
  status    RefundStatus @default(PENDING)
  decisionAt DateTime?
  reason    String?
  eligibleAt DateTime
  computedEligibilitySnapshot Json

  user User @relation(fields: [userId], references: [id])
}

model VerificationSlot {
  id        String   @id @default(uuid())
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())
  isBooked  Boolean  @default(false)
  userId    String?

  user User? @relation(fields: [userId], references: [id])

  @@index([startAt])
  @@index([userId])
}

model VerificationRequest {
  id        String @id @default(uuid())
  userId    String
  status    VerificationRequestStatus @default(REQUESTED)
  // Nullable while requests are in progress or finalized.
  verificationLink String?
  meetUrl   String?
  linkExpiresAt DateTime?
  createdAt DateTime @default(now())
  completedAt DateTime?
  decidedAt DateTime?
  decidedBy String?
  assignedEmployeeId String?
  assignedAt DateTime?
  reason    String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  type        NotificationType
  userId      String
  actorUserId String?
  matchId     String?
  title       String?
  message     String?
  imageUrl    String?
  deepLinkUrl String?
  metadata    Json?
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
  readAt      DateTime?

  user  User  @relation("userNotifications", fields: [userId], references: [id])
  actor User? @relation("notificationActors", fields: [actorUserId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])

  @@unique([userId, type, actorUserId, matchId])
  @@index([userId])
  @@index([matchId])
}

model AuditLog {
  id          String @id @default(uuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String
  metadata    Json
  createdAt   DateTime @default(now())

  actor User? @relation("actorLogs", fields: [actorUserId], references: [id])
}
