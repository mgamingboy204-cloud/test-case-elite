# Application Settings
NODE_ENV=development
PORT=4000

# Origins (Allowed http://localhost in development)
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/elite

# Authentication (JWT-only)
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
ACCESS_TOKEN_TTL_MINUTES=60
ACCESS_TOKEN_TTL_MINUTES_SHORT=30
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TTL_DAYS_SHORT=7

# Storage Configuration
STORAGE_PROVIDER=local # or 'supabase'
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
