# Application Settings
NODE_ENV=development
PORT=4000
ALLOW_TEST_BYPASS=false
DEV_OTP_LOG=false

# Origins (Allowed http://localhost in development)
WEB_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000
ADMIN_ORIGIN=http://localhost:3001
API_ORIGIN=http://localhost:4000

# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/elite

# Session / Authentication
SESSION_SECRET=replace-with-strong-session-secret
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
ACCESS_TOKEN_TTL_MINUTES=60
ACCESS_TOKEN_TTL_MINUTES_SHORT=30
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TTL_DAYS_SHORT=7

# Storage Configuration
STORAGE_PROVIDER=local # or 'supabase'
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# OTP Provider
# - mock: internal OTP provider (default mock code: 123456)
# - twilio: Twilio Verify API
OTP_PROVIDER=mock
OTP_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payment Provider
# - mock: internal payment provider (same /payments/initiate -> /payments/verify flow)
# - razorpay: Razorpay Orders + signature verification
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
