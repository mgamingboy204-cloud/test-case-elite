# Application Settings
NODE_ENV=development
PORT=4000
ALLOW_TEST_BYPASS=true
DEV_OTP_LOG=true

# Origins (Allowed http://localhost in development)
WEB_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000
ADMIN_ORIGIN=http://localhost:3001
API_ORIGIN=http://localhost:4000

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/elite

# Session / Authentication
SESSION_SECRET=dev-session-secret-change-in-production
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
ACCESS_TOKEN_TTL_MINUTES=60
ACCESS_TOKEN_TTL_MINUTES_SHORT=30
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TTL_DAYS_SHORT=7

# Storage Configuration
STORAGE_PROVIDER=local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# OTP Provider
OTP_PROVIDER=mock
OTP_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payment Provider
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
